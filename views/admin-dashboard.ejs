<%- include('partials/header') %>

<section class="container section">
  <h1 class="page-title">Bảng điều khiển quản trị</h1>

  <div class="dashboard-stats">
    <div class="stat-card"><span class="stat-number"><%= totalUsers %></span><span class="stat-label">Học sinh</span></div>
    <div class="stat-card"><span class="stat-number"><%= totalTeachers %></span><span class="stat-label">Giáo viên</span></div>
    <div class="stat-card"><span class="stat-number"><%= totalCourses %></span><span class="stat-label">Khóa học</span></div>
    <div class="stat-card"><span class="stat-number"><%= totalAttempts %></span><span class="stat-label">Lượt làm bài</span></div>
  </div>

  <h2 class="section-title">Người dùng mới nhất</h2>
  <table class="data-table">
    <thead><tr><th>Họ tên</th><th>Email</th><th>Vai trò</th><th>Ngày tạo</th></tr></thead>
    <tbody>
      <% recentUsers.forEach(u => { %>
        <tr>
          <td><%= u.full_name %></td>
          <td><%= u.email %></td>
          <td><%= u.role %></td>
          <td><%= u.created_at %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<%- include('partials/footer') %>
